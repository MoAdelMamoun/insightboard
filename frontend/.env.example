# InsightBoard frontend runs as a fully static DEMO with ZERO config — it reads
# the bundled seed dataset, so no backend or keys are needed.
#
# Optionally point it at the FastAPI backend (../backend) for the full version
# with live ingest + persistence. Copy to `.env.local` and set:

# Base URL of the InsightBoard API (e.g. http://localhost:8000). Leave blank to
# use the bundled demo data only.
NEXT_PUBLIC_API_URL=

# Base path if hosting under a subdirectory (e.g. "/insightboard" on GitHub
# Pages project sites). Leave blank for root hosting.
NEXT_PUBLIC_BASE_PATH=

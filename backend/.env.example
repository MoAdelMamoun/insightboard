# InsightBoard backend (FastAPI). All optional — sensible defaults are built in,
# and the database auto-seeds with demo data on first run.

# SQLite database file path
DATABASE_PATH=insightboard.db

# Comma-separated allowed origins for CORS (the frontend dev server, your
# deployed frontend, etc.). "*" allows all — fine for a public demo.
CORS_ORIGINS=*

# Port the API listens on
PORT=8000
